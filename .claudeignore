# .claudeignore — files Claude Code skips during context loading
# Generated by /bootstrap (Rails API project)

# Dependencies
vendor/bundle/
node_modules/

# Logs & temp
log/
tmp/
coverage/
.byebug_history

# Build artifacts
public/assets/
public/packs/
public/packs-test/

# Database files
db/*.sqlite3
db/*.sqlite3-journal

# Pipeline / harness state (not source)
.pipeline/
.worktrees/

# Environment secrets
.env
.env.*
!.env.example

# OS/editor artifacts
.DS_Store
*.swp
*.swo
.idea/
.vscode/

# Spring (Rails preloader) sockets
/tmp/pids/
/tmp/cache/
/tmp/sockets/
